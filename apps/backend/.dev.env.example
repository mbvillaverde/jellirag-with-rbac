# JellieRAG backend env (local dev). Copy to .env and fill in.
# In production these are injected by environment variables — never baked into
# the image or committed. All AI providers are OpenAI-compatible HTTP endpoints.

# ---- AI providers (OpenAI-compatible) ----
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_API_KEY=ollama
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768
LLM_TIMEOUT_SECONDS=5

# ---- database ----
SQLITE_PATH=/var/jellirag/jellyrag.db

# ---- sync service ----
SYNC_EMBED_CONCURRENCY=4

# ---- homelab overlay (Tailscale-only) ----
JELLYFIN_TAILSCALE_URL=http://jellyfin.<tailnet>.ts.net:8096
JELLYFIN_API_KEY=replace-me
JELLYFIN_DEEPLINK_BASE=http://jellyfin.<tailnet>.ts.net:8096

# ---- conversation lifecycle ----
SESSION_TTL_DAYS=30

# ---- auth perimeter ----
JWT_SECRET=replace-me-with-a-long-random-string
JWT_TTL_DAYS=7
# Bootstrap admin (used ONCE if the users table is empty, then ignored):
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# ---- CORS (comma-separated exact origins) ----
FRONTEND_ORIGIN=http://localhost:3000

# ---- sync schedule (cron) ----
SYNC_CRON=0 3 * * *
