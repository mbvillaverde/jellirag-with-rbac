# JellieRAG backend env (local dev). Copy to .env and fill in.
# In production these are injected by Dokploy encrypted env (never baked into
# the image or committed). NO Cloudflare credential lives here or on the VPS —
# only the Jellyfin key, the broker secret, the deeplink base, the JWT secret,
# and the one-shot bootstrap-admin pair.

# ---- broker boundary (the only path to Cloudflare) ----
BROKER_URL=http://localhost:8787
BROKER_SECRET=replace-me

# ---- homelab overlay (Tailscale-only) ----
JELLYFIN_TAILSCALE_URL=http://jellyfin.<tailnet>.ts.net:8096
JELLYFIN_API_KEY=replace-me
JELLYFIN_DEEPLINK_BASE=http://jellyfin.<tailnet>.ts.net:8096

# ---- conversation lifecycle ----
SESSION_TTL_DAYS=30

# ---- auth perimeter ----
JWT_SECRET=replace-me-with-a-long-random-string
JWT_TTL_DAYS=7
# Bootstrap admin (used ONCE if the users table is empty, then ignored):
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# ---- CORS (comma-separated exact origins) ----
FRONTEND_ORIGIN=http://localhost:3000

# ---- sync schedule (cron) ----
SYNC_CRON=0 3 * * *
